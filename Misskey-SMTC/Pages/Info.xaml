<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Misskey_SMTC.Pages.Info"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Misskey_SMTC.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:ui="using:CommunityToolkit.WinUI"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Name="infoContentGrid" TargetType="Grid">
            <Setter Property="Padding" Value="16"/>
            <Setter Property="CornerRadius" Value="{StaticResource ControlCornerRadius}"/>
            <Setter Property="Background" Value="{StaticResource CardBackgroundFillColorDefaultBrush}"/>
        </Style>

        <Style x:Name="infoContentHeader" TargetType="TextBlock" BasedOn="{StaticResource BodyStrongTextBlockStyle}">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Name="infoContentBody" TargetType="TextBlock" BasedOn="{StaticResource BodyTextBlockStyle}">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Name="copyClipboardButton" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="ToolTipService.ToolTip" Value="クリップボードにコピー"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!--  TitleBar  -->
            <RowDefinition Height="*" />
            <!--  NavigationView  -->
        </Grid.RowDefinitions>
        <TextBlock Text="Info" Style="{StaticResource TitleTextBlockStyle}" Margin="0 0 0 24"
            Grid.Row="0" />
        <StackPanel Orientation="Vertical" Spacing="4" Grid.Row="1">

            <Grid Style="{StaticResource infoContentGrid}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="4*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Title" Grid.Column="0"
                    Style="{StaticResource infoContentHeader}"/>
                <TextBlock Text="{x:Bind SongInfo.Title, Mode=OneWay}" Grid.Column="1"
                    Style="{StaticResource infoContentBody}"/>
                <Button Grid.Column="2" Click="CopyText_Click"
                    Tag="{x:Bind SongInfo.Title, Mode=OneWay}"
                    Style="{StaticResource copyClipboardButton}">
                    <FontIcon Glyph="&#xE8C8;" />
                </Button>
            </Grid>

            <Grid Style="{StaticResource infoContentGrid}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="4*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Subtitle" Grid.Column="0"
                    Style="{StaticResource infoContentHeader}"/>
                <TextBlock Text="{x:Bind SongInfo.Subtitle, Mode=OneWay}" Grid.Column="1"
                    Style="{StaticResource infoContentBody}"/>
                <Button Grid.Column="2" Click="CopyText_Click"
                    Tag="{x:Bind SongInfo.Subtitle, Mode=OneWay}"
                    Style="{StaticResource copyClipboardButton}">
                    <FontIcon Glyph="&#xE8C8;" />
                </Button>
            </Grid>

            <Grid Style="{StaticResource infoContentGrid}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="4*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Artist" Grid.Column="0"
                    Style="{StaticResource infoContentHeader}"/>
                <TextBlock Text="{x:Bind SongInfo.Artist, Mode=OneWay}" Grid.Column="1"
                    Style="{StaticResource infoContentBody}"/>
                <Button Grid.Column="2" Click="CopyText_Click"
                    Tag="{x:Bind SongInfo.Artist, Mode=OneWay}"
                    Style="{StaticResource copyClipboardButton}">
                    <FontIcon Glyph="&#xE8C8;" />
                </Button>
            </Grid>

            <Grid Style="{StaticResource infoContentGrid}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="4*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="AlbumArtist" Grid.Column="0"
                    Style="{StaticResource infoContentHeader}"/>
                <TextBlock Text="{x:Bind SongInfo.AlbumArtist, Mode=OneWay}" Grid.Column="1"
                    Style="{StaticResource infoContentBody}"/>
                <Button Grid.Column="2" Click="CopyText_Click"
                    Tag="{x:Bind SongInfo.AlbumArtist, Mode=OneWay}"
                    Style="{StaticResource copyClipboardButton}">
                    <FontIcon Glyph="&#xE8C8;" />
                </Button>
            </Grid>

            <Grid Style="{StaticResource infoContentGrid}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="4*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="AlbumTitle" Grid.Column="0"
                    Style="{StaticResource infoContentHeader}"/>
                <TextBlock Text="{x:Bind SongInfo.AlbumTitle, Mode=OneWay}" Grid.Column="1"
                    Style="{StaticResource infoContentBody}"/>
                <Button Grid.Column="2" Click="CopyText_Click"
                    Tag="{x:Bind SongInfo.AlbumTitle, Mode=OneWay}"
                    Style="{StaticResource copyClipboardButton}">
                    <FontIcon Glyph="&#xE8C8;" />
                </Button>
            </Grid>

            <Grid Style="{StaticResource infoContentGrid}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="4*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="TrackNumber" Grid.Column="0"
                    Style="{StaticResource infoContentHeader}"/>
                <TextBlock Text="{x:Bind SongInfo.TrackNumber, Mode=OneWay}" Grid.Column="1"
                    Style="{StaticResource infoContentBody}"/>
                <Button Grid.Column="2" Click="CopyText_Click"
                    Tag="{x:Bind SongInfo.TrackNumber, Mode=OneWay}"
                    Style="{StaticResource copyClipboardButton}">
                    <FontIcon Glyph="&#xE8C8;" />
                </Button>
            </Grid>

            <Grid Style="{StaticResource infoContentGrid}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="4*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="AlbumTrackCount" Grid.Column="0"
                    Style="{StaticResource infoContentHeader}"/>
                <TextBlock Text="{x:Bind SongInfo.AlbumTrackCount, Mode=OneWay}" Grid.Column="1"
                    Style="{StaticResource infoContentBody}"/>
                <Button Grid.Column="2" Click="CopyText_Click"
                    Tag="{x:Bind SongInfo.AlbumTrackCount, Mode=OneWay}"
                    Style="{StaticResource copyClipboardButton}">
                    <FontIcon Glyph="&#xE8C8;" />
                </Button>
            </Grid>

            <Grid Style="{StaticResource infoContentGrid}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="4*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="GenresText" Grid.Column="0"
                    Style="{StaticResource infoContentHeader}"/>
                <TextBlock Text="{x:Bind SongInfo.GenresText, Mode=OneWay}" Grid.Column="1"
                    Style="{StaticResource infoContentBody}"/>
                <Button Grid.Column="2" Click="CopyText_Click"
                    Tag="{x:Bind SongInfo.GenresText, Mode=OneWay}"
                    Style="{StaticResource copyClipboardButton}">
                    <FontIcon Glyph="&#xE8C8;" />
                </Button>
            </Grid>

            <Grid Style="{StaticResource infoContentGrid}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="4*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="PlaybackType" Grid.Column="0"
                    Style="{StaticResource infoContentHeader}"/>
                <TextBlock Text="{x:Bind SongInfo.PlaybackType, Mode=OneWay}" Grid.Column="1"
                    Style="{StaticResource infoContentBody}"/>
                <Button Grid.Column="2" Click="CopyText_Click"
                    Tag="{x:Bind SongInfo.PlaybackType, Mode=OneWay}"
                    Style="{StaticResource copyClipboardButton}">
                    <FontIcon Glyph="&#xE8C8;" />
                </Button>
            </Grid>

            <Grid Style="{StaticResource infoContentGrid}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="4*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Id" Grid.Column="0"
                    Style="{StaticResource infoContentHeader}"/>
                <TextBlock Text="{x:Bind SongInfo.Id, Mode=OneWay}" Grid.Column="1"
                    Style="{StaticResource infoContentBody}"/>
                <Button Grid.Column="2" Click="CopyText_Click"
                    Tag="{x:Bind SongInfo.Id, Mode=OneWay}"
                    Style="{StaticResource copyClipboardButton}">
                    <FontIcon Glyph="&#xE8C8;" />
                </Button>
            </Grid>
        </StackPanel>
    </Grid>
</Page>
