<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Misskey_SMTC.Pages.Misskey"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Misskey_SMTC.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:ui="using:CommunityToolkit.WinUI"
    xmlns:Misskey_SMTC="using:Misskey_SMTC.Creditional"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!--  TitleBar  -->
            <RowDefinition Height="*" />
            <!--  NavigationView  -->
        </Grid.RowDefinitions>

        <TextBlock Text="登録済みMisskeyサーバー" Style="{StaticResource TitleTextBlockStyle}"
            Margin="0 0 0 24" Grid.Row="0" />

        <StackPanel Orientation="Vertical" Grid.Row="1">
            <!-- 登録済みサーバーリスト -->
            <TextBlock
                Text="登録済みサーバー"
                Style="{StaticResource BodyStrongTextBlockStyle}"
                Margin="0,0,0,4" />

            <!-- サーバーが0件のとき -->
            <InfoBar
                x:Name="EmptyInfoBar"
                IsOpen="True"
                IsClosable="False"
                Severity="Informational"
                Title="サーバーが登録されていません"
                Message="下のフォームからサーバーを追加してください" />


            <!-- 新しいサーバーを追加 -->
            <controls:SettingsExpander x:Name="AddServerExpander"
                Header="新しいサーバーを登録する"
                Margin="0,8,0,0">
                <controls:SettingsExpander.HeaderIcon>
                    <FontIcon Glyph="&#xE710;" />
                </controls:SettingsExpander.HeaderIcon>

                <controls:SettingsExpander.Items>
                    <controls:SettingsCard Header="サーバーURL">
                        <TextBox x:Name="ServerUrlInput"
                            PlaceholderText="例: misskey.io"
                            Width="240" />
                    </controls:SettingsCard>

                    <controls:SettingsCard>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="LoginButton"
                                Content="ブラウザで認証する"
                                Style="{StaticResource AccentButtonStyle}"
                                Click="OnLoginClicked" />
                            <Button x:Name="CancelButton"
                                Content="キャンセル"
                                IsEnabled="False"
                                Click="OnCancelClicked" />
                        </StackPanel>
                    </controls:SettingsCard>

                    <!-- ステータス表示 -->
                    <controls:SettingsCard x:Name="StatusCard" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <ProgressRing x:Name="AuthProgressRing" IsActive="False" Width="20"
                                Height="20" />
                            <TextBlock x:Name="StatusTextBlock" VerticalAlignment="Center" />
                        </StackPanel>
                    </controls:SettingsCard>

                </controls:SettingsExpander.Items>
            </controls:SettingsExpander>

            <StackPanel Orientation="Vertical" Grid.Row="1" Spacing="4">
                <!-- 登録済みサーバー一覧 -->
                <ItemsControl x:Name="ServerList" ItemsSource="{x:Bind Servers}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="Misskey_SMTC:ServerEntry">
                            <controls:SettingsExpander
                                Header="{x:Bind DisplayName, Mode=OneWay}"
                                Description="{x:Bind ServerUrl}">
                                <controls:SettingsExpander.HeaderIcon>
                                    <FontIcon Glyph="&#xE909;" />
                                </controls:SettingsExpander.HeaderIcon>
                                <Button Content="削除"
                                    Tag="{x:Bind ServerUrl}"
                                    Click="OnRemoveClicked"
                                    Style="{StaticResource DefaultButtonStyle}" />
                                <controls:SettingsExpander.Items>
                                    <controls:SettingsCard Header="表示名">
                                        <TextBox Tag="{x:Bind ServerUrl}"
                                                 Text="{x:Bind RawDisplayName, Mode=TwoWay}"
                                                 PlaceholderText="省略時はサーバーURLを表示"
                                                 Width="240"
                                                 LostFocus="OnDisplayNameChanged"/>
                                    </controls:SettingsCard>
                                    <controls:SettingsCard Header="デフォルトの投稿先">
                                        <ToggleSwitch Tag="{x:Bind ServerUrl}"
                                                      IsOn="{x:Bind IsDefault, Mode=TwoWay}"
                                                      Toggled="OnDefaultServerToggled"/>
                                    </controls:SettingsCard>
                                </controls:SettingsExpander.Items>
                            </controls:SettingsExpander>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

        </StackPanel>
    </Grid>
</Page>
