<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Misskey_SMTC.Pages.Post"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Misskey_SMTC.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:ui="using:CommunityToolkit.WinUI"
    xmlns:Misskey_SMTC="using:Misskey_SMTC.Creditional"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!--  TitleBar  -->
            <RowDefinition Height="*" />
            <!--  NavigationView  -->
        </Grid.RowDefinitions>
        <TextBlock Text="Misskeyにノートする" Style="{StaticResource TitleTextBlockStyle}"
            Margin="0 0 0 24" Grid.Row="0" />

        <StackPanel Orientation="Vertical" Spacing="4" Grid.Row="1">
            <controls:SettingsCard Header="今すぐ投稿する">
                <Button x:Name="PostNP"
                    Content="Post NowPlaying"
                    Style="{StaticResource AccentButtonStyle}"
                    IsEnabled="{x:Bind CanPost, Mode=OneWay}"
                    Click="OnPostNowPlaying" />
            </controls:SettingsCard>

            <controls:SettingsCard Header="投稿先サーバー">
                <ComboBox x:Name="ServerSelector"
                    PlaceholderText="サーバーを選択してください"
                    ItemsSource="{x:Bind Servers}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="Misskey_SMTC:ServerEntry">
                            <TextBlock Text="{x:Bind DisplayName, Mode=OneWay}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </controls:SettingsCard>

            <controls:SettingsCard Header="Apple Music 互換モード"
                Description="Artist フィールドからアーティスト名とアルバム名を分離して表示します">
                <ToggleSwitch IsOn="{x:Bind SongInfo.AppleMusicCompat, Mode=TwoWay}"
                    OnContent="有効" OffContent="無効" />
            </controls:SettingsCard>

            <controls:SettingsExpander Header="投稿テンプレート">
                <controls:SettingsExpander.HeaderIcon>
                    <FontIcon Glyph="&#xE70F;"/>
                </controls:SettingsExpander.HeaderIcon>
                <Button Content="編集" Click="OnEditTemplate"/>
                <controls:SettingsExpander.Items>
<!--                    <StackPanel Padding="60 12 32 12" Background="{StaticResource CardBackgroundFillColorDefaultBrush}" Spacing="8">
                        <TextBlock Text="プレビュー" Style="{StaticResource BodyTextBlockStyle}"/>
                        <TextBlock Text="{x:Bind PreviewText, Mode=OneWay}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{StaticResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>-->
                    <controls:SettingsCard Header="プレビュー" Description="{x:Bind PreviewText, Mode=OneWay}"/>
                </controls:SettingsExpander.Items>
            </controls:SettingsExpander>
        </StackPanel>
    </Grid>
</Page>
